{
  "name": "pkc-js-benchmarks",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "start": "node start.ts",
    "benchmark:browser": "vitest run --config config/vitest.browser.config.ts",
    "benchmark:node": "vitest run --config config/vitest.node.config.ts",
    "benchmark:server": "nodemon --ext ts --exec 'node scripts/start-server.ts'",
    "report": "node lib/print-report.ts",
    "report:inline": "node lib/print-report.ts --inline",
    "check": "tsc --noEmit"
  },
  "author": "",
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "@bitsocial/bso-resolver": "0.0.8",
    "@pkcprotocol/pkc-js": "0.0.30",
    "cborg": "5.1.1",
    "debug": "4.4.3",
    "decompress": "4.2.1",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "fs-extra": "11.3.5",
    "http-proxy": "1.18.1",
    "http-proxy-agent": "9.0.0",
    "https-proxy-agent": "9.0.0",
    "javascript-time-ago": "2.6.4",
    "kubo-rpc-client": "6.1.0",
    "multiformats": "14.0.0",
    "node-fetch": "3.3.2",
    "nodemon": "3.1.14",
    "p-queue": "9.2.0",
    "p-timeout": "7.0.1",
    "peer-id": "0.16.0",
    "progress": "2.0.3",
    "prom-client": "15.1.3",
    "string-strip-html": "13.5.3",
    "tcp-port-used": "1.0.2",
    "uint8arrays": "6.1.1",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "@types/debug": "4.1.13",
    "@types/decompress": "4.2.7",
    "@types/express": "5.0.6",
    "@types/fs-extra": "11.0.4",
    "@types/http-proxy": "1.17.17",
    "@types/javascript-time-ago": "2.5.0",
    "@types/node": "25.6.2",
    "@types/progress": "2.0.7",
    "@types/tcp-port-used": "1.0.4",
    "@types/yargs": "17.0.35",
    "@vitest/browser": "4.1.5",
    "@vitest/browser-playwright": "4.1.5",
    "playwright": "1.59.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
